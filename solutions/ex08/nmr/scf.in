&control
    calculation = 'scf'
    prefix = 'uracil'
    restart_mode = 'from_scratch'
    tstress = .true.
    tprnfor = .true.
    pseudo_dir = '/home/rr/calc_QE/qe-gipaw-7.1/pseudo/'
    outdir = '/home/rr/calc_QE/uracil/nmr'
    verbosity = 'high'
/

&system
    input_dft = 'pbe'
    ibrav = 0
    nat = 48
    ntyp = 4
    ecutwfc = 50
    ! ecutrho can be added if needed (e.g. for US/PAW pseudopotentials)
    ! ecutrho = 200
/

&electrons
    diagonalization = 'davidson'
    diago_thr_init = 1.0d-4
    mixing_mode = 'plain'
    mixing_beta = 0.7
    conv_thr = 1.0d-10
/

